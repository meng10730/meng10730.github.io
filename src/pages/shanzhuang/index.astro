---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const novels = await getCollection('novels', entry => !entry.id.startsWith('_'));
const characters = await getCollection('characters', entry => !entry.id.startsWith('_'));
const guoxue = await getCollection('guoxue', entry => !entry.id.startsWith('_'));
const worldview = await getCollection('worldview', entry => !entry.id.startsWith('_'));
const factions = await getCollection('factions', entry => !entry.id.startsWith('_'));

const categories = [
  {
    id: 'novels',
    title: '藏書閣',
    name: '小說連載',
    desc: '閣中存卷，江湖故事，躍然紙上。包含仙俠、武俠長篇創作。',
    count: novels.length,
    unit: '卷存書',
    link: 'novels',
    icon: '📜'
  },
  {
    id: 'characters',
    title: '俠客譜',
    name: '人物誌設定',
    desc: '江湖豪傑，正邪門派，群俠列傳。記載人物生平、功法與關係。',
    count: characters.length,
    unit: '名俠客',
    link: 'characters',
    icon: '⚔️'
  },
  {
    id: 'guoxue',
    title: '研經室',
    name: '國學筆記',
    desc: '幾案研經，讀書札記，修身齊家。涵蓋儒道釋、古典詩詞與史籍。',
    count: guoxue.length,
    unit: '則筆記',
    link: 'guoxue',
    icon: '✍️'
  },
  {
    id: 'worldview',
    title: '風物誌',
    name: '世界觀設定',
    desc: '玄理風物，天地運行，設定奧秘。揭示功法機制、天地劫數與地理。',
    count: worldview.length,
    unit: '則設定',
    link: 'worldview',
    icon: '🗺️'
  },
  {
    id: 'factions',
    title: '群雄會',
    name: '勢力組織',
    desc: '江湖割據，名門暗潮，群雄並起。記載門派起落、勢力爭奪與地盤。',
    count: factions.length,
    unit: '方勢力',
    link: 'factions',
    icon: '🏯'
  }
];
---

<Layout title="後山 | 創作與筆記" description="後山藏書閣，包含小說連載、人物設定、國學筆記、世界觀與勢力組織">
  <div class="shanzhuang-container ink-fade-in">
    <h1 class="page-title">後山</h1>
    <p class="page-subtitle cursive-title">「一盞清茶論江湖，半壁江山寫墨意」</p>
    <div class="mountain-line"></div>

    <!-- 一鍵續讀卡片 (預設隱藏，由 Client-side JS 讀取 localStorage 後動態顯現) -->
    <div id="resume-read-card" class="resume-read-card hidden ink-fade-in">
      <div class="resume-content">
        <span class="resume-tag cursive-title">🔖 續讀</span>
        <div class="resume-details">
          <span class="resume-title"></span>
          <span class="resume-progress"></span>
        </div>
      </div>
      <a href="#" class="resume-btn font-semibold">繼續閱讀 ➔</a>
    </div>

    <!-- 古風竹簡書架清單佈局 -->
    <div class="shanzhuang-list-container">
      {categories.map(cat => (
        <a href={`${import.meta.env.BASE_URL}shanzhuang/${cat.link}`} class="shanzhuang-list-item paper-card">
          <div class="item-left">
            <span class="item-icon">{cat.icon}</span>
            <div class="item-title-group">
              <h2 class="item-title cursive-title">{cat.title}</h2>
              <span class="item-name">{cat.name}</span>
            </div>
          </div>
          <p class="item-desc">{cat.desc}</p>
          <div class="item-right">
            <span class="item-count-badge">
              <span class="count-num">{cat.count}</span> {cat.unit}
            </span>
            <span class="item-action-btn">翻閱 ➔</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<script>
  // 讀取閱讀進度並顯示卡片
  function checkResumeRead() {
    const card = document.getElementById('resume-read-card');
    if (!card) return;

    try {
      const raw = localStorage.getItem('shanzhuang_last_read');
      if (raw) {
        const record = JSON.parse(raw);
        // 進度在 2% 到 95% 之間時，才顯示續讀橫幅（避免已看完的章節佔版面）
        if (record && record.url && record.percent > 0.02 && record.percent < 0.95) {
          const titleSpan = card.querySelector('.resume-title');
          const progressSpan = card.querySelector('.resume-progress');
          const btn = card.querySelector('.resume-btn');
          
          const typeMap = {
            novels: '藏書閣 · 小說',
            characters: '俠客譜 · 人物',
            worldview: '風物誌 · 設定',
            factions: '群雄會 · 組織',
            guoxue: '研經室 · 國學'
          };
          
          const typeText = typeMap[record.type] || '設定';
          const percentText = Math.round(record.percent * 100);
          
          if (titleSpan) titleSpan.innerText = `《${record.title}》`;
          if (progressSpan) progressSpan.innerText = `分類：${typeText} | 已讀進度：${percentText}% | 閱讀時間：${new Date(record.updatedAt).toLocaleDateString('zh-TW')} ${new Date(record.updatedAt).toLocaleTimeString('zh-TW', { hour: '2-digit', minute: '2-digit' })}`;
          if (btn) btn.href = record.url;
          
          card.classList.remove('hidden');
          return;
        }
      }
    } catch (e) {}
    card.classList.add('hidden');
  }

  function initShanzhuangHome() {
    checkResumeRead();
  }

  document.addEventListener('astro:page-load', initShanzhuangHome);
  initShanzhuangHome();
</script>

<style>
  .shanzhuang-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
    position: relative;
  }
  
  .page-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 0.2rem;
  }
  
  .page-subtitle {
    text-align: center;
    color: var(--color-ink-grey);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  /* 竹簡書單清單佈局容器 */
  .shanzhuang-list-container {
    max-width: 800px;
    margin: 3rem auto 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 3rem;
  }

  /* 單個書單長條 - 宣紙底色，水墨細邊 */
  .shanzhuang-list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    border-radius: 6px;
    background: var(--color-paper-light);
    border: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-ink-text);
    transition: var(--transition-smooth);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.015);
    position: relative;
    overflow: hidden;
    gap: 2rem;
  }

  .shanzhuang-list-item:hover {
    border-color: var(--color-mountain-cyan);
    background: rgba(253, 252, 247, 0.98);
    transform: translateX(6px);
    box-shadow: 0 6px 20px rgba(45, 95, 90, 0.05);
  }

  /* 左側：圖示與標題組 */
  .item-left {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-shrink: 0;
  }

  .item-icon {
    font-size: 2rem;
    opacity: 0.85;
  }

  .item-title-group {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .item-title {
    font-size: 1.3rem;
    color: var(--color-mountain-cyan);
    margin: 0;
    line-height: 1.2;
  }

  .item-name {
    font-size: 0.85rem;
    color: var(--color-ink-grey);
    letter-spacing: 0.05em;
  }

  /* 中間：介紹描述 (無固定高度限制，字體精巧為 0.9rem) */
  .item-desc {
    flex: 1;
    font-size: 0.9rem;
    color: var(--color-ink-text);
    line-height: 1.6;
    margin: 0;
  }

  /* 右側：數量徽章與按鈕 */
  .item-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  .item-count-badge {
    font-size: 0.8rem;
    background: rgba(45, 95, 90, 0.05);
    color: var(--color-mountain-cyan);
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
    border: 1px solid rgba(45, 95, 90, 0.1);
    font-weight: 600;
    white-space: nowrap;
  }

  .count-num {
    font-size: 1.05rem;
    font-family: var(--font-cursive);
    color: var(--color-mountain-green);
  }

  .item-action-btn {
    font-size: 0.9rem;
    color: var(--color-mountain-cyan);
    font-weight: bold;
    transition: var(--transition-fast);
    white-space: nowrap;
  }

  .shanzhuang-list-item:hover .item-action-btn {
    color: var(--color-mountain-green);
  }

  /* 一鍵續讀卡片水墨風樣式 */
  .resume-read-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(250, 248, 245, 0.95);
    border: 1px solid #d9d2c9;
    border-radius: 4px;
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    box-shadow: 0 4px 12px rgba(44, 37, 32, 0.06);
    border-left: 3px solid #a63f3f; /* 朱泥紅點綴 */
    font-family: 'LXGW WenKai TC', 'Noto Serif TC', serif;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  
  .resume-read-card.hidden {
    display: none !important;
  }
  
  .resume-content {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  
  .resume-tag {
    font-size: 0.95rem;
    color: #a63f3f;
    background: rgba(166, 63, 63, 0.05);
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    border: 1px solid rgba(166, 63, 63, 0.15);
    white-space: nowrap;
  }
  
  .resume-details {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  
  .resume-title {
    font-size: 1.05rem;
    font-weight: bold;
    color: #1a1512;
  }
  
  .resume-progress {
    font-size: 0.8rem;
    color: #8c7f73;
  }
  
  .resume-btn {
    font-size: 0.9rem;
    color: #a63f3f;
    text-decoration: none;
    transition: transform 0.2s ease;
  }
  
  .resume-btn:hover {
    color: var(--color-mountain-green);
    transform: translateX(4px);
  }

  /* 響應式佈局：當螢幕寬度較小時，允許垂直平鋪，但仍維持良好的美感 */
  @media (max-width: 768px) {
    .resume-read-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      width: 100%;
      box-sizing: border-box;
    }
    
    .resume-btn {
      align-self: flex-end;
    }

    .shanzhuang-list-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.5rem;
    }

    .item-left {
      width: 100%;
    }

    .item-desc {
      width: 100%;
    }

    .item-right {
      width: 100%;
      justify-content: space-between;
      border-top: 1px dashed var(--color-border);
      padding-top: 0.8rem;
      margin-top: 0.2rem;
    }
  }
</style>
