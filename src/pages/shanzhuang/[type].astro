---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  return [
    { params: { type: 'novels' }, props: { title: '藏書閣 · 小說列表', subtitle: '閣中存卷，江湖故事，躍然紙上。' } },
    { params: { type: 'characters' }, props: { title: '俠客譜 · 人物列表', subtitle: '江湖豪傑，正邪門派，群俠列傳。' } },
    { params: { type: 'guoxue' }, props: { title: '研經室 · 國學筆記', subtitle: '幾案研經，讀書札記，修身齊家。' } },
    { params: { type: 'worldview' }, props: { title: '風物誌 · 世界觀設定', subtitle: '玄理風物，天地運行，設定奧秘。' } },
    { params: { type: 'factions' }, props: { title: '群雄會 · 勢力組織', subtitle: '江湖割據，名門暗潮，群雄並起。' } },
    { params: { type: 'items' }, props: { title: '法寶神兵列表', subtitle: '江湖神兵，天地法寶記載。' } },
    { params: { type: 'techniques' }, props: { title: '功法秘笈列表', subtitle: '江湖功法，神功秘笈記載。' } },
    { params: { type: 'bestiary' }, props: { title: '靈獸妖魔列表', subtitle: '天地靈獸，大千妖魔記載。' } }
    // [ADD_NEW_COLLECTION_PATH_HERE]
  ];
}

const { type } = Astro.params;
const { title, subtitle } = Astro.props;

const items = await getCollection(type as any, (entry: any) => !entry.id.startsWith('_'));

const allNovels = await getCollection('novels', (entry: any) => !entry.id.startsWith('_'));
const findNovelSlug = (novelTitle: string) => {
  const matched = allNovels.find((n: any) => n.data.title === novelTitle);
  return matched ? matched.slug : null;
};

const RENDER_CONFIG: Record<string, Record<string, string>> = {
  // [ADD_NEW_COLLECTION_RENDER_CONFIG_HERE]
};

// 排序：預設按發布日期排序（如果有）
items.sort((a: any, b: any) => {
  const dateA = new Date((a.data as any).pubDate || 0).getTime();
  const dateB = new Date((b.data as any).pubDate || 0).getTime();
  return dateB - dateA;
});

// 若為勢力分類，動態生成 Mermaid 勢力關係圖譜字串
let mermaidCode = '';
if (type === 'factions') {
  const charactersList = await getCollection('characters', (entry: any) => !entry.id.startsWith('_'));
  
  mermaidCode = 'graph TD\n';
  // 設定 Mermaid 的樣式
  mermaidCode += '  %% Styles\n';
  mermaidCode += '  classDef faction fill:#fbfaf7,stroke:#8a6c55,stroke-width:2px,color:#2c2520,font-family:LXGW WenKai TC;\n';
  mermaidCode += '  classDef character fill:#faf8f5,stroke:#d9d2c9,stroke-width:1px,color:#594f46,font-family:LXGW WenKai TC;\n';

  items.forEach((faction: any) => {
    const fId = `f_${faction.slug.replace(/[^a-zA-Z0-9]/g, '_')}`;
    const fName = faction.data.title;
    mermaidCode += `  ${fId}["🏯 ${fName}"]\n`;
    mermaidCode += `  class ${fId} faction;\n`;

    // 篩選屬於此勢力的登場人物
    const members = charactersList.filter((char: any) => char.data.affiliation === fName);
    members.forEach((member: any) => {
      const cId = `c_${member.slug.replace(/[^a-zA-Z0-9]/g, '_')}`;
      const cName = member.data.name;
      mermaidCode += `  ${fId} --> ${cId}["⚔️ ${cName}"]\n`;
      mermaidCode += `  class ${cId} character;\n`;
    });
  });
}

const novelStatusMap: Record<string, string> = {
  ongoing: '連載中',
  completed: '已完結',
  hiatus: '暫停中'
};

const guoxueCatMap: Record<string, string> = {
  confucianism: '儒家',
  taoism: '道家',
  buddhism: '佛家',
  history: '史籍',
  poetry: '詩詞',
  other: '其他'
};
---

<Layout title={`${title} | 唐門山莊`} description={subtitle}>
  <div class="shanzhuang-container ink-fade-in">
    <div class="back-link-wrapper">
      <a href={`${import.meta.env.BASE_URL}shanzhuang`} class="back-link">
        ← 返回山莊主頁
      </a>
    </div>

    <h1 class="page-title cursive-title">{title}</h1>
    <p class="page-subtitle cursive-title">「{subtitle}」</p>
    <div class="mountain-line"></div>

    {type === 'factions' && items.length > 0 && (
      <div class="factions-chart-wrapper paper-card ink-fade-in">
        <details class="chart-details">
          <summary class="chart-summary cursive-title">🗺️ 展開勢力山河圖（Mermaid 關係圖譜）</summary>
          <div class="mermaid-container">
            <pre class="mermaid">{mermaidCode}</pre>
          </div>
        </details>
      </div>
    )}

    {items.length === 0 ? (
      <div class="empty-state paper-card">
        <p>此閣目前尚無卷軸記載，待莊主提筆修書...</p>
      </div>
    ) : (
      <div class="villa-grid">
        {items.map((item: any) => {
          const slug = item.slug;
          const data = item.data as any;
          return (
            <div class="villa-card paper-card">
              <div class="card-meta">
                {type === 'novels' && (
                  <>
                    <span class={`status-badge ${data.status}`}>
                      {novelStatusMap[data.status] || data.status}
                    </span>
                    {data.genre && (
                      <span class="genre-tags">
                        {data.genre.map((g: any) => (
                          <span class="genre-tag">#{g}</span>
                        ))}
                      </span>
                    )}
                  </>
                )}
                {type === 'characters' && (
                  <>
                    {data.affiliation && <span class="affiliation">{data.affiliation}</span>}
                    {data.novel && <span class="novel-ref">《{data.novel}》</span>}
                  </>
                )}
                {type === 'guoxue' && (
                  <>
                    <span class="category-badge">
                      {guoxueCatMap[data.category] || data.category}
                    </span>
                    {data.source && <span class="source-ref">{data.source}</span>}
                  </>
                )}
                {type === 'worldview' && (
                  <>
                    <span class="category-badge">世界觀</span>
                    {data.category && <span class="source-ref">{data.category}</span>}
                  </>
                )}
                {type === 'factions' && (
                  <>
                    <span class="category-badge">勢力</span>
                    {data.category && <span class="source-ref">{data.category}</span>}
                  </>
                )}
              </div>

              <h3 class="card-title">
                <a href={`${import.meta.env.BASE_URL}shanzhuang/${type}/${slug}`}>
                  {data.title || data.name}
                  {type === 'characters' && data.alias && data.alias.length > 0 && (
                    <span class="alias-title">（{data.alias.join(' / ')}）</span>
                  )}
                </a>
              </h3>

              {type === 'novels' && <p class="card-desc">{data.description}</p>}
              {type === 'characters' && data.tags && (
                <div class="char-tags">
                  {data.tags.map((t: any) => (
                    <span class="char-tag">{t}</span>
                  ))}
                </div>
              )}
              {type === 'guoxue' && data.tags && (
                <div class="note-tags">
                  {data.tags.map((t: any) => (
                    <span class="note-tag">{t}</span>
                  ))}
                </div>
              )}
              {type === 'worldview' && data.pubDate && (
                <p class="card-desc text-xs text-ink-grey">發布於 {new Date(data.pubDate).toLocaleDateString('zh-TW')}</p>
              )}
              {type === 'factions' && data.pubDate && (
                <p class="card-desc text-xs text-ink-grey">創建於 {new Date(data.pubDate).toLocaleDateString('zh-TW')}</p>
              )}

              <div class="card-footer">
                <a href={`${import.meta.env.BASE_URL}shanzhuang/${type}/${slug}`} class="read-btn">
                  {type === 'novels' && '翻閱小說 →'}
                  {type === 'characters' && '人物誌 →'}
                  {type === 'guoxue' && '研讀筆記 →'}
                  {type === 'worldview' && '研讀設定 →'}
                  {type === 'factions' && '探尋勢力 →'}
                </a>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>

  {type === 'factions' && (
    <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
    <script is:inline>
      function initMermaid() {
        if (window.mermaid) {
          window.mermaid.initialize({
            startOnLoad: true,
            theme: 'neutral',
            securityLevel: 'loose',
            flowchart: {
              useWidth: 900,
              htmlLabels: true
            }
          });
          // 重建以利 ViewTransitions 觸發
          window.mermaid.init(undefined, document.querySelectorAll('.mermaid'));
        }
      }
      document.addEventListener('astro:page-load', initMermaid);
      initMermaid();
    </script>
  )}
</Layout>

<style>
  /* Mermaid 勢力山河圖古風樣式 */
  .factions-chart-wrapper {
    margin-bottom: 2rem;
    padding: 1.5rem 2rem;
    background: rgba(250, 248, 245, 0.95);
    border: 1px solid #d9d2c9;
    border-radius: 4px;
    box-shadow: 0 4px 12px rgba(44, 37, 32, 0.06);
  }

  .chart-details {
    width: 100%;
  }

  .chart-summary {
    font-size: 1.15rem;
    color: var(--color-mountain-cyan);
    cursor: pointer;
    user-select: none;
    outline: none;
    font-weight: bold;
    transition: color 0.2s ease;
  }

  .chart-summary:hover {
    color: var(--color-mountain-green);
  }

  .mermaid-container {
    margin-top: 1.5rem;
    width: 100%;
    overflow-x: auto;
    background: rgba(255, 255, 255, 0.5);
    border-radius: 4px;
    padding: 1rem;
    border: 1px dashed rgba(138, 108, 85, 0.2);
    display: flex;
    justify-content: center;
  }

  /* 調整 Mermaid 節點在霞鶩字型下的水墨風視覺效果 */
  :global(.mermaid) {
    font-family: 'LXGW WenKai TC', 'Noto Serif TC', serif !important;
  }
  
  :global(.mermaid .node rect), :global(.mermaid .node circle), :global(.mermaid .node polygon) {
    fill: #fbfaf7 !important;
    stroke: #8a6c55 !important;
    stroke-width: 1.5px !important;
    rx: 4px;
    ry: 4px;
  }

  :global(.mermaid .edgePath .path) {
    stroke: #8a6c55 !important;
    stroke-width: 1.5px !important;
  }

  :global(.mermaid .edgeArrowOps .arrowMarkerPath) {
    fill: #8a6c55 !important;
    stroke: none !important;
  }

  :global(.mermaid .label) {
    color: #2c2520 !important;
    font-weight: 600 !important;
  }

  .shanzhuang-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  
  .back-link-wrapper {
    margin-bottom: 1.5rem;
  }
  
  .back-link {
    font-size: 0.95rem;
    color: var(--color-mountain-cyan);
    font-weight: 600;
  }
  
  .back-link:hover {
    color: var(--color-mountain-green);
  }

  .page-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 0.2rem;
  }
  
  .page-subtitle {
    text-align: center;
    color: var(--color-ink-grey);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }
  
  .villa-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  
  .villa-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
  }
  
  .card-meta {
    font-size: 0.8rem;
    color: var(--color-ink-grey);
    margin-bottom: 0.8rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  
  .status-badge {
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  
  .status-badge.ongoing {
    background: rgba(196, 140, 59, 0.1);
    color: var(--color-mountain-accent);
    border: 1px solid rgba(196, 140, 59, 0.2);
  }
  
  .status-badge.completed {
    background: rgba(61, 126, 90, 0.1);
    color: var(--color-mountain-green);
    border: 1px solid rgba(61, 126, 90, 0.2);
  }
  
  .status-badge.hiatus {
    background: rgba(92, 92, 92, 0.1);
    color: var(--color-ink-grey);
    border: 1px solid rgba(92, 92, 92, 0.2);
  }
  
  .genre-tag {
    margin-left: 0.3rem;
    color: var(--color-mountain-cyan);
  }
  
  .card-title {
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
  }
  
  .card-title a {
    color: var(--color-ink-black);
    transition: var(--transition-fast);
  }
  
  .card-title a:hover {
    color: var(--color-mountain-cyan);
  }
  
  .alias-title {
    font-size: 0.9rem;
    color: var(--color-ink-grey);
    font-weight: normal;
  }
  
  .card-desc {
    font-size: 0.95rem;
    color: var(--color-ink-text);
    line-height: 1.6;
    margin-bottom: 1.2rem;
    flex-grow: 1;
  }
  
  .char-tags, .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.2rem;
  }
  
  .char-tag, .note-tag {
    font-size: 0.75rem;
    background: rgba(45, 95, 90, 0.05);
    color: var(--color-mountain-cyan);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    border: 1px solid rgba(45, 95, 90, 0.1);
  }
  
  .affiliation {
    background: rgba(61, 126, 90, 0.08);
    color: var(--color-mountain-green);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }
  
  .category-badge {
    background: rgba(0, 0, 0, 0.04);
    color: var(--color-ink-black);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-weight: 600;
  }
  
  .card-footer {
    border-top: 1px dashed var(--color-border);
    padding-top: 0.8rem;
    margin-top: auto;
  }
  
  .read-btn {
    font-size: 0.9rem;
    color: var(--color-mountain-cyan);
    font-weight: 600;
    transition: var(--transition-fast);
    display: inline-block;
  }
  
  .read-btn:hover {
    color: var(--color-mountain-green);
    transform: translateX(4px);
  }
  
  .empty-state {
    text-align: center;
    padding: 2.5rem 1.5rem;
    color: var(--color-ink-grey);
    font-style: italic;
  }
</style>
