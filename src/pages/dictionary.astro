---
// C:\workspace\個人網站架設\src\pages\dictionary.astro
// Astro Frontmatter (Executed server-side on build, empty since all query logic runs client-side dynamically)
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>古典文言寫作助手 - 雙軌寫作大師端</title>
  <!-- 載入 Google Fonts: Outfit (現代字體) & Noto Serif TC (典雅古典字體) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700;900&family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
  
  <style>
    /* CSS Reset & Variable Definitions */
    :root {
      --bg-dark: #05070f;
      --panel-glass: rgba(13, 17, 30, 0.75);
      --border-glass: rgba(255, 255, 255, 0.08);
      --primary-glow: linear-gradient(135deg, #8b5cf6 0%, #06b6d4 100%);
      --accent-purple: #8b5cf6;
      --accent-cyan: #06b6d4;
      --text-main: #f3f4f6;
      --text-muted: #9ca3af;
      --serif-font: 'Noto Serif TC', serif;
      --sans-font: 'Outfit', sans-serif;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg-dark);
      background-image: 
        radial-gradient(circle at 10% 20%, rgba(139, 92, 246, 0.15) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(6, 182, 212, 0.15) 0%, transparent 45%);
      background-attachment: fixed;
      color: var(--text-main);
      font-family: var(--sans-font);
      min-height: 100vh;
      overflow-x: hidden;
      padding: 2rem 1rem;
    }

    /* Container & Header Layout */
    .container {
      max-width: 1100px;
      margin: 0 auto;
    }

    header {
      text-align: center;
      margin-bottom: 2.5rem;
      position: relative;
    }

    header h1 {
      font-family: var(--serif-font);
      font-weight: 900;
      font-size: 2.8rem;
      letter-spacing: 2px;
      background: var(--primary-glow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 0.5rem;
      text-shadow: 0 0 40px rgba(139, 92, 246, 0.2);
    }

    header p {
      color: var(--text-muted);
      font-size: 1.05rem;
      font-weight: 300;
    }

    /* Tabs Navigation */
    .tabs-nav {
      display: flex;
      justify-content: center;
      gap: 0.8rem;
      margin-bottom: 1.8rem;
    }

    .tab-btn {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border-glass);
      color: var(--text-muted);
      padding: 0.75rem 1.6rem;
      border-radius: 12px;
      cursor: pointer;
      font-size: 0.95rem;
      font-weight: 600;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      backdrop-filter: blur(10px);
    }

    .tab-btn:hover {
      border-color: rgba(6, 182, 212, 0.4);
      color: var(--text-main);
      transform: translateY(-2px);
    }

    .tab-btn.active {
      background: var(--primary-glow);
      border-color: transparent;
      color: #fff;
      box-shadow: 0 4px 20px rgba(139, 92, 246, 0.35);
    }

    /* Glassmorphism Control Panel */
    .control-panel {
      background: var(--panel-glass);
      border: 1px solid var(--border-glass);
      border-radius: 20px;
      padding: 2rem;
      backdrop-filter: blur(20px);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
      margin-bottom: 2.5rem;
      position: relative;
    }

    .tab-content {
      display: none;
    }

    .tab-content.active {
      display: block;
      animation: fadeIn 0.4s ease;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Grid Layout for Forms */
    .form-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-group label {
      font-size: 0.85rem;
      color: var(--accent-cyan);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* Custom Inputs, Selects & Toggles */
    input[type="text"], select {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border-glass);
      color: var(--text-main);
      padding: 0.8rem 1rem;
      border-radius: 10px;
      font-size: 0.95rem;
      outline: none;
      transition: all 0.3s ease;
      font-family: inherit;
    }

    input[type="text"]:focus, select:focus {
      border-color: var(--accent-cyan);
      box-shadow: 0 0 15px rgba(6, 182, 212, 0.2);
      background: rgba(255, 255, 255, 0.07);
    }

    select option {
      background: #0f172a;
      color: var(--text-main);
    }

    /* Hide Common Word Segment Control */
    .common-toggle-group {
      display: flex;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border-glass);
      border-radius: 10px;
      overflow: hidden;
      padding: 2px;
    }

    .common-toggle-btn {
      flex: 1;
      border: none;
      background: transparent;
      color: var(--text-muted);
      padding: 0.6rem;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      border-radius: 8px;
    }

    .common-toggle-btn.active {
      background: rgba(255, 255, 255, 0.08);
      color: var(--text-main);
    }

    /* Buttons Container */
    .button-group {
      display: flex;
      gap: 1rem;
      justify-content: flex-end;
      align-items: center;
    }

    .primary-btn {
      background: var(--primary-glow);
      color: #fff;
      border: none;
      padding: 0.9rem 2.2rem;
      border-radius: 12px;
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(139, 92, 246, 0.3);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .primary-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 25px rgba(139, 92, 246, 0.45);
    }

    .primary-btn:active {
      transform: translateY(0);
    }

    /* Glowing Dice Button for Random Concept */
    .dice-btn {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border-glass);
      color: var(--accent-cyan);
      padding: 0.9rem;
      border-radius: 12px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
    }

    .dice-btn:hover {
      background: rgba(6, 182, 212, 0.1);
      border-color: var(--accent-cyan);
      color: #fff;
      transform: rotate(45deg) translateY(-2px);
      box-shadow: 0 0 20px rgba(6, 182, 212, 0.3);
    }

    /* Result Area layout */
    .result-container {
      margin-top: 2rem;
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    /* Premium Result Card styling */
    .word-card {
      background: rgba(13, 17, 30, 0.45);
      border: 1px solid var(--border-glass);
      border-radius: 16px;
      padding: 1.8rem;
      backdrop-filter: blur(15px);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
      position: relative;
      overflow: hidden;
    }

    .word-card:hover {
      border-color: rgba(139, 92, 246, 0.25);
      background: rgba(13, 17, 30, 0.6);
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(139, 92, 246, 0.1);
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
      padding-bottom: 0.8rem;
    }

    .word-title-group {
      display: flex;
      align-items: baseline;
      gap: 0.8rem;
    }

    .word-glyph {
      font-family: var(--serif-font);
      font-size: 2.2rem;
      font-weight: 900;
      color: #fff;
      text-shadow: 0 0 10px rgba(255, 255, 255, 0.15);
    }

    .word-bopomofo {
      font-size: 1rem;
      color: var(--accent-cyan);
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .pos-badge {
      background: rgba(139, 92, 246, 0.15);
      border: 1px solid rgba(139, 92, 246, 0.3);
      color: #c084fc;
      padding: 0.35rem 0.75rem;
      border-radius: 20px;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .definition-block {
      display: flex;
      flex-direction: column;
      gap: 0.8rem;
    }

    .allusion-box {
      background: rgba(255, 255, 255, 0.02);
      border-left: 3px solid var(--accent-purple);
      padding: 0.8rem 1rem;
      border-radius: 0 8px 8px 0;
      font-family: var(--serif-font);
      font-size: 0.95rem;
      color: #e5e7eb;
      line-height: 1.6;
    }

    .allusion-box strong {
      color: var(--accent-purple);
      margin-right: 0.5rem;
      font-weight: 700;
    }

    .meaning-box {
      font-size: 0.95rem;
      color: var(--text-muted);
      line-height: 1.7;
    }

    .meaning-box strong {
      color: var(--text-main);
      font-weight: 600;
      margin-right: 0.4rem;
    }

    /* Synonym card specific layouts */
    .synonym-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .syn-badge-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .syn-pill {
      background: rgba(6, 182, 212, 0.12);
      border: 1px solid rgba(6, 182, 212, 0.25);
      color: #22d3ee;
      padding: 0.4rem 0.8rem;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .opp-pill {
      background: rgba(239, 68, 68, 0.12);
      border: 1px solid rgba(239, 68, 68, 0.25);
      color: #f87171;
      padding: 0.4rem 0.8rem;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    /* Pagination layout */
    .pagination-bar {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 1.5rem;
      margin-top: 2.5rem;
      margin-bottom: 4rem;
    }

    .pagination-btn {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid var(--border-glass);
      color: var(--text-muted);
      width: 44px;
      height: 44px;
      border-radius: 50%;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
    }

    .pagination-btn:hover:not(:disabled) {
      border-color: var(--accent-cyan);
      color: #fff;
      transform: scale(1.05);
      box-shadow: 0 0 15px rgba(6, 182, 212, 0.2);
    }

    .pagination-btn:disabled {
      opacity: 0.25;
      cursor: not-allowed;
    }

    .page-info {
      font-size: 0.95rem;
      color: var(--text-muted);
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .page-info span {
      color: var(--text-main);
    }

    /* Loading Spinner */
    .loader {
      display: none;
      justify-content: center;
      align-items: center;
      padding: 4rem 0;
    }

    .spinner {
      width: 40px;
      height: 40px;
      border: 3px solid rgba(255, 255, 255, 0.05);
      border-top: 3px solid var(--accent-cyan);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    /* Empty state info */
    .empty-state {
      text-align: center;
      padding: 5rem 0;
      color: var(--text-muted);
      font-family: var(--serif-font);
      font-size: 1.15rem;
      border: 1px dashed var(--border-glass);
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.01);
    }

    .empty-state p {
      margin-bottom: 0.5rem;
    }

    .empty-state span {
      font-size: 0.9rem;
      color: rgba(255, 255, 255, 0.25);
    }
  </style>
</head>
<body>

  <div class="container">
    <header>
      <h1>古典文言寫作助手</h1>
      <p>極簡純淨 ‧ 意境借代 ‧ 雙軌寫作大師端</p>
    </header>

    <!-- Navigation Tabs -->
    <nav class="tabs-nav">
      <button class="tab-btn active" data-tab="mode-1">意境寫作模式</button>
      <button class="tab-btn" data-tab="mode-2">古籍文獻檢索</button>
      <button class="tab-btn" data-tab="mode-4">同義/反義查詢</button>
    </nav>

    <!-- Glass Control Panel -->
    <div class="control-panel">
      <!-- 模式 1 Form: 意境寫作 -->
      <div id="mode-1" class="tab-content active">
        <div class="form-grid">
          <div class="form-group">
            <label for="m1-core">核心意境詞</label>
            <input type="text" id="m1-core" placeholder="如 '月' (多詞用空格隔開)" />
          </div>
          <div class="form-group">
            <label for="m1-assoc">聯想詞/動作</label>
            <input type="text" id="m1-assoc" placeholder="選填 (如 '照')" />
          </div>
          <div class="form-group">
            <label for="m1-pos">篩選詞性</label>
            <select id="m1-pos">
              <option value="">不限詞性</option>
              <option value="[名]">名詞</option>
              <option value="[動]">動詞</option>
              <option value="[形]">形容詞</option>
              <option value="[副]">副詞</option>
            </select>
          </div>
          <div class="form-group">
            <label>常用字過濾</label>
            <div class="common-toggle-group" id="m1-common-switch">
              <button class="common-toggle-btn active" data-val="y">靠後</button>
              <button class="common-toggle-btn" data-val="n">不靠後</button>
              <button class="common-toggle-btn" data-val="h">隱藏</button>
            </div>
          </div>
        </div>
      </div>

      <!-- 模式 2 Form: 古籍文獻 -->
      <div id="mode-2" class="tab-content">
        <div class="form-grid">
          <div class="form-group" style="grid-column: span 2;">
            <label for="m2-book">古籍書名</label>
            <input type="text" id="m2-book" placeholder="如 '天工開物'、'莊子'" />
          </div>
          <div class="form-group">
            <label for="m2-query">引文關鍵字</label>
            <input type="text" id="m2-query" placeholder="選填 (如 '鐵'、'劍')" />
          </div>
          <div class="form-group">
            <label for="m2-pos">篩選詞性</label>
            <select id="m2-pos">
              <option value="">不限詞性</option>
              <option value="[名]">名詞</option>
              <option value="[動]">動詞</option>
              <option value="[形]">形容詞</option>
              <option value="[副]">副詞</option>
            </select>
          </div>
        </div>
      </div>

      <!-- 模式 4 Form: 同義反義 -->
      <div id="mode-4" class="tab-content">
        <div class="form-grid">
          <div class="form-group" style="grid-column: span 4;">
            <label for="m4-word">查詢目標字詞</label>
            <input type="text" id="m4-word" placeholder="請輸入待替換的字詞 (如 '寒')" />
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="button-group">
        <!-- 骰子隨機模式 -->
        <button class="dice-btn" id="random-insp-btn" title="隨機召喚靈感意境">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
            <circle cx="9" cy="9" r="2"></circle>
            <circle cx="15" cy="15" r="2"></circle>
            <circle cx="15" cy="9" r="2"></circle>
            <circle cx="9" cy="15" r="2"></circle>
          </svg>
        </button>
        <!-- 核心查詢 -->
        <button class="primary-btn" id="search-action-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          檢索文言
        </button>
      </div>
    </div>

    <!-- Spinner Loading -->
    <div class="loader" id="query-loader">
      <div class="spinner"></div>
    </div>

    <!-- Dynamic Output Panel -->
    <main class="result-container" id="results-viewport">
      <div class="empty-state">
        <p>書卷未開，意境未澄。</p>
        <span>請輸入關鍵字並點選「檢索文言」開啟查詢。</span>
      </div>
    </main>

    <!-- Pagination Controls -->
    <div class="pagination-bar" id="pagination-controls" style="display: none;">
      <button class="pagination-btn" id="prev-page-btn" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <div class="page-info">
        第 <span id="current-page-num">1</span> / <span id="total-page-num">1</span> 頁
      </div>
      <button class="pagination-btn" id="next-page-btn" disabled>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>

  <!-- Client-Side JavaScript Logic -->
  <script>
    const API_BASE = "http://localhost:5001/api/query";
    const PAGE_SIZE = 12;

    // State Variables
    let activeMode = "mode-1";
    let currentResultsData = [];
    let currentPageIdx = 0;
    let currentCommonFilter = "y";

    // DOM Elements
    const tabButtons = document.querySelectorAll(".tab-btn");
    const tabContents = document.querySelectorAll(".tab-content");
    const searchActionBtn = document.getElementById("search-action-btn");
    const randomInspBtn = document.getElementById("random-insp-btn");
    const loader = document.getElementById("query-loader");
    const resultsViewport = document.getElementById("results-viewport");
    
    const paginationControls = document.getElementById("pagination-controls");
    const prevPageBtn = document.getElementById("prev-page-btn");
    const nextPageBtn = document.getElementById("next-page-btn");
    const currentPageNum = document.getElementById("current-page-num");
    const totalPageNum = document.getElementById("total-page-num");

    // Common Word Toggle Switcher logic
    const commonToggleBtns = document.querySelectorAll("#m1-common-switch .common-toggle-btn");
    commonToggleBtns.forEach(btn => {
      btn.addEventListener("click", () => {
        commonToggleBtns.forEach(b => b.classList.remove("active"));
        btn.classList.add("active");
        currentCommonFilter = btn.getAttribute("data-val");
      });
    });

    // Navigation Tab switching logic
    tabButtons.forEach(button => {
      button.addEventListener("click", () => {
        tabButtons.forEach(btn => btn.classList.remove("active"));
        tabContents.forEach(content => content.classList.remove("active"));
        
        button.classList.add("active");
        activeMode = button.getAttribute("data-tab");
        document.getElementById(activeMode).classList.add("active");
      });
    });

    // Render Paginated Results in DOM
    function renderPage() {
      resultsViewport.innerHTML = "";
      const totalResults = currentResultsData.length;
      
      if (totalResults === 0) {
        paginationControls.style.display = "none";
        resultsViewport.innerHTML = `
          <div class="empty-state">
            <p>無尋覓結果</p>
            <span>未找到符合要求的古典單字，請試試其他查詢條件。</span>
          </div>`;
        return;
      }

      // Display Pagination
      const totalPages = Math.ceil(totalResults / PAGE_SIZE);
      paginationControls.style.display = "flex";
      currentPageNum.textContent = currentPageIdx + 1;
      totalPageNum.textContent = totalPages;
      
      prevPageBtn.disabled = currentPageIdx === 0;
      nextPageBtn.disabled = currentPageIdx + 1 >= totalPages;

      const start = currentPageIdx * PAGE_SIZE;
      const end = Math.min(start + PAGE_SIZE, totalResults);

      // Render Cards
      for (let i = start; i < end; i++) {
        const item = currentResultsData[i];
        
        if (activeMode === "mode-4") {
          // Synonym Lookup rendering
          const card = document.createElement("div");
          card.className = "word-card";
          card.innerHTML = `
            <div class="card-header">
              <div class="word-title-group">
                <span class="word-glyph">${item.word}</span>
                ${item.bopomofo ? `<span class="word-bopomofo">（${item.bopomofo}）</span>` : ""}
              </div>
            </div>
            <div class="synonym-grid">
              <div class="meaning-box"><strong>白話釋義：</strong>${item.explanation}</div>
              <div class="syn-badge-row">
                <span class="syn-pill">同義詞：${item.similar || "[無]"}</span>
                <span class="opp-pill">反義詞：${item.opposite || "[無]"}</span>
              </div>
            </div>`;
          resultsViewport.appendChild(card);
        } else {
          // Concept and Book query rendering
          const card = document.createElement("div");
          card.className = "word-card";
          
          let definitionsHTML = "";
          item.definitions.forEach(d => {
            definitionsHTML += `
              <div class="definition-block">
                <div class="allusion-box">
                  <strong>典故</strong>${d.citation}
                </div>
                <div class="meaning-box">
                  <strong>釋義</strong>${d.explanation}
                </div>
              </div>`;
          });

          card.innerHTML = `
            <div class="card-header">
              <div class="word-title-group">
                <span class="word-glyph">${item.word}</span>
                ${item.bopomofo ? `<span class="word-bopomofo">（${item.bopomofo}）</span>` : ""}
              </div>
              <span class="pos-badge">${item.definitions[0].pos}</span>
            </div>
            ${definitionsHTML}`;
          resultsViewport.appendChild(card);
        }
      }
      
      // Auto scroll to top of viewport
      resultsViewport.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Execute API Fetch Request
    async function performSearch(urlParamsSpec) {
      loader.style.display = "flex";
      resultsViewport.innerHTML = "";
      paginationControls.style.display = "none";

      try {
        const response = await fetch(`${API_BASE}?${urlParamsSpec}`);
        if (!response.ok) throw new Error("HTTP error " + response.status);
        const data = await response.json();
        
        currentResultsData = data;
        currentPageIdx = 0;
        renderPage();
      } catch (err) {
        resultsViewport.innerHTML = `
          <div class="empty-state">
            <p>資料庫連接失敗</p>
            <span>請檢查 Python API 伺服器 (port 5001) 是否已啟動，並在背景運行。</span>
          </div>`;
      } finally {
        loader.style.display = "none";
      }
    }

    // Core Search Click Handler
    searchActionBtn.addEventListener("click", () => {
      let queryStr = "";
      
      if (activeMode === "mode-1") {
        const core = document.getElementById("m1-core").value.strip ? document.getElementById("m1-core").value.strip() : document.getElementById("m1-core").value;
        const assoc = document.getElementById("m1-assoc").value.strip ? document.getElementById("m1-assoc").value.strip() : document.getElementById("m1-assoc").value;
        const pos = document.getElementById("m1-pos").value;
        if (!core) {
          alert("請輸入核心意境詞！");
          return;
        }
        queryStr = `mode=1&core=${encodeURIComponent(core)}&assoc=${encodeURIComponent(assoc)}&common=${currentCommonFilter}`;
        if (pos) queryStr += `&pos=${encodeURIComponent(pos)}`;
      } 
      else if (activeMode === "mode-2") {
        const book = document.getElementById("m2-book").value.strip ? document.getElementById("m2-book").value.strip() : document.getElementById("m2-book").value;
        const query = document.getElementById("m2-query").value.strip ? document.getElementById("m2-query").value.strip() : document.getElementById("m2-query").value;
        const pos = document.getElementById("m2-pos").value;
        if (!book) {
          alert("請輸入古籍名稱！");
          return;
        }
        queryStr = `mode=2&book=${encodeURIComponent(book)}`;
        if (query) queryStr += `&query=${encodeURIComponent(query)}`;
        if (pos) queryStr += `&pos=${encodeURIComponent(pos)}`;
      }
      else if (activeMode === "mode-4") {
        const word = document.getElementById("m4-word").value.strip ? document.getElementById("m4-word").value.strip() : document.getElementById("m4-word").value;
        if (!word) {
          alert("請輸入要查詢同義詞的字！");
          return;
        }
        queryStr = `mode=4&word=${encodeURIComponent(word)}`;
      }

      performSearch(queryStr);
    });

    // Random Concept Click Handler (Mode 3)
    randomInspBtn.addEventListener("click", async () => {
      loader.style.display = "flex";
      resultsViewport.innerHTML = "";
      paginationControls.style.display = "none";

      try {
        const response = await fetch(`${API_BASE}?mode=3`);
        if (!response.ok) throw new Error("HTTP error " + response.status);
        const data = await response.json();
        
        // Auto switch tab visual and state back to Mode 1 to show results
        tabButtons.forEach(btn => btn.classList.remove("active"));
        tabContents.forEach(content => content.classList.remove("active"));
        
        const mode1Btn = document.querySelector('[data-tab="mode-1"]');
        mode1Btn.classList.add("active");
        activeMode = "mode-1";
        document.getElementById("mode-1").classList.add("active");
        
        // Autofill input core word with random concept
        document.getElementById("m1-core").value = data.concept;
        document.getElementById("m1-assoc").value = "";
        
        // Focus results
        currentResultsData = data.results;
        currentPageIdx = 0;
        
        // Show success flash effect on console
        renderPage();
      } catch (err) {
        resultsViewport.innerHTML = `
          <div class="empty-state">
            <p>資料庫連接失敗</p>
            <span>請檢查 Python API 伺服器 (port 5001) 是否已啟動。</span>
          </div>`;
      } finally {
        loader.style.display = "none";
      }
    });

    // Pagination Click Listeners
    prevPageBtn.addEventListener("click", () => {
      if (currentPageIdx > 0) {
        currentPageIdx--;
        renderPage();
      }
    });

    nextPageBtn.addEventListener("click", () => {
      const totalPages = Math.ceil(currentResultsData.length / PAGE_SIZE);
      if (currentPageIdx + 1 < totalPages) {
        currentPageIdx++;
        renderPage();
      }
    });
  </script>
</body>
</html>
